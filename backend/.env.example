# ─── Server ──────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:8080

# ─── PostgreSQL ──────────────────────────────────────────────
# Option A: Full connection string (recommended for Neon / Supabase / RDS)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Option B: Discrete connection params (uncomment if not using DATABASE_URL)
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=messmate
# PGSSL=false

# Pool tuning (optional – defaults shown)
# PG_POOL_MAX=10

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT Secrets ─────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars_long
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars_long
JWT_QR_SECRET=change_me_qr_secret_min_32_chars_long

# ─── Token TTLs ─────────────────────────────────────────────
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
QR_TOKEN_TTL_SECONDS=8

# ─── Email Notifications (Resend - https://resend.com) ──────
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=Mom's Kitchen <onboarding@resend.dev>

# ─── Push Notifications (VAPID) ─────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="[Your Generated VAPID Public Key]"
VAPID_PRIVATE_KEY="[Your Generated VAPID Private Key]"
VAPID_SUBJECT="mailto:your-email@gmail.com"

# ─── Client / Frontend ──────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Cron (secure external triggers like cron-job.org) ──────
CRON_SECRET_TOKEN=development_cron_secret_token

# ─── Worker ──────────────────────────────────────────────────
# Set to "true" in single-process deployments (e.g. Render) so the
# BullMQ email/push worker runs inside the same process as the API.
RUN_WORKER=true

# Set to "true" ONLY when running worker.js as a standalone process.
# RUN_STANDALONE_WORKER=false
