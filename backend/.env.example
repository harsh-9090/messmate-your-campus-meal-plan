# Server
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:8080

# PostgreSQL - either set DATABASE_URL or the discrete PG* vars
DATABASE_URL=postgres://postgres:postgres@localhost:5432/messmate
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=messmate
# PGSSL=false   # set to "true" for managed providers (Neon, Supabase, RDS)

# Redis
REDIS_URL=redis://localhost:6379

# JWT secrets (use openssl rand -hex 32 in production)
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars_long
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars_long
JWT_QR_SECRET=change_me_qr_secret_min_32_chars_long

# Token TTLs
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
QR_TOKEN_TTL_SECONDS=8

# Notifications (Resend - https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=Mom's Kitchen <onboarding@resend.dev>

# Client Configuration
FRONTEND_URL=http://localhost:5173

# Cron Configuration (For secure external triggers like cron-job.org)
CRON_SECRET_TOKEN=development_cron_secret_token
# npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="[Your Generated VAPID Public Key]"
VAPID_PRIVATE_KEY="[Your Generated VAPID Private Key]"
VAPID_SUBJECT="mailto:your-email@gmail.com"

# Worker (set to "true" in production single-process deployments like Render)
RUN_WORKER=true
